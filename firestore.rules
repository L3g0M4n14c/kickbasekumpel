rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Authentifizierte Benutzer können ihre eigenen Daten lesen und schreiben
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Ligainsider Spielerdaten: Öffentlich lesbar (Bundesliga-Spielerstatistiken
    // und Fotos sind öffentlich verfügbare Sportdaten ohne persönlichen Bezug),
    // nur Backend (Cloud Functions via Admin SDK) kann schreiben
    match /players/{playerId} {
      allow read: if true;
      allow write: if false; // Nur Admin SDK (Cloud Functions)
    }

    // Ligainsider Spielerfotos: normalisierter Name → photoUrl
    // Geschrieben von Cloud Functions (Admin SDK), öffentlich lesbar
    match /ligainsider_photos/{docId} {
      allow read: if true;
      allow write: if false; // Nur Admin SDK (Cloud Functions)
    }

    // Scraper Metadaten: Öffentlich lesbar (nur operative Metadaten)
    match /scraper_metadata/{docId} {
      allow read: if true;
      allow write: if false; // Nur Admin SDK (Cloud Functions)
    }

    // KI-Empfehlungen: Öffentlich les- und schreibbar
    // (Lokal vom Gerät generierte Daten, kein sensibler Inhalt)
    match /recommendations/{recommendationId} {
      allow read, write: if true;
    }

    // Alle anderen Dokumente: Zugriff verweigert
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
